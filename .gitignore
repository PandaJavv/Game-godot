# Godot 4+ specific ignores
.godot/
*.translation

# Exported APKs (artifacts handled by CI)
export/*.apk
export/*.aab

# Android build artifacts
android/build/.gradle/
android/build/build/
android/build/.cxx/

# OS specific
.DS_Store
Thumbs.db

# Keystore (NEVER commit this!)
*.jks
*.keystore

# Editor-specific
.idea/
*.sln
*.csproj

# Temporary files
*.tmp
*.bak
*~
